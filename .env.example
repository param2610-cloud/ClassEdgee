# ClassEdgee - Environment Variables Template
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE (Neon PostgreSQL - Free Tier)
# ===========================================
DATABASE_URL="postgresql://username:password@host.neon.tech/neondb?sslmode=require"
DB_HOST="host.neon.tech"
DB_NAME="neondb"
DB_USER="username"
DB_PASSWORD="password"

# ===========================================
# CLOUDINARY (Image/Model Storage - Free Tier)
# ===========================================
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_UPLOAD_PRESET="your_upload_preset"

# ===========================================
# JWT & AUTH
# ===========================================
JWT_SECRET="your_super_secret_jwt_key_here"
JWT_EXPIRES_IN="7d"

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3000
PYTHON_BACKEND_URL="http://localhost:8000"
FRONTEND_URL="http://localhost:5173"

# ===========================================
# QUEUE + FACE PIPELINE
# ===========================================
RABBITMQ_URL="amqp://localhost:5672"
FACE_PRESENT_MIN_FRAMES=2
FACE_SINGLE_FRAME_HIGH_CONF=0.8

# ===========================================
# OPENAI (Optional - for chatbot)
# ===========================================
OPENAI_API_KEY="your_openai_api_key"

# ===========================================
# EMAIL (Optional - for notifications)
# ===========================================
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password"

# ===========================================
# PRODUCTION URLs (Update after deployment)
# ===========================================
# FRONTEND_URL="https://your-app.vercel.app"
# MAIN_BACKEND_URL="https://your-backend.railway.app"
# PYTHON_BACKEND_URL="https://your-python-backend.railway.app"
